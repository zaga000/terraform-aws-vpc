# Local .terraform directories
**/.terraform/*

# .tfstate files (Дуже важливо для безпеки!)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore tfplan files
*.tfplan

#Ignore lock file
.terraform.lock.hcl

# Other files to ignore
vpcs.txt